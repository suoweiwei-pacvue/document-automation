# LLM Configuration
# Pacvue Gateway: https://llm-gateway-test.pacvue.com
# 可用模型: pacvue-opus-4-6, pacvue-sonnet-4-6, pacvue-bedrock-4-6
OPENAI_API_KEY=your-api-key
OPENAI_API_BASE=https://llm-gateway-test.pacvue.com
LLM_MODEL=pacvue-opus-4-6
EMBEDDING_MODEL=openai/amazon.titan-embed-text-v2

# GitHub Configuration
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=Pacvue
GITHUB_REPO_FRONTEND=CustomDashboard-modules-web
GITHUB_REPO_BACKEND=custom-dashboard
GITHUB_FRONTEND_BRANCH=master
GITHUB_BACKEND_BRANCH=production

# Confluence Configuration
# API Token 生成: https://id.atlassian.com/manage-profile/security/api-tokens
CONFLUENCE_URL=https://pacvue-enterprise.atlassian.net
CONFLUENCE_USERNAME=your-email@pacvue.com
CONFLUENCE_API_TOKEN=your-confluence-api-token
CONFLUENCE_TECH_PAGE_ID=2752762
CONFLUENCE_PRD_PAGE_ID=3441902,1385365659

# ChromaDB Configuration
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=cd_knowledge_base

# Output Configuration
OUTPUT_DIR=./output
